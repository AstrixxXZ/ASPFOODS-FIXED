@using Microsoft.AspNetCore.Identity
@using ASP_Foods2.Data
@inject SignInManager<Client> SignInManager
@inject UserManager<Client> UserManager

<ul class="navbar-nav nav-auth align-items-center">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link greeting" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            👋 Hello, @User.Identity?.Name!
        </a>
    </li>
    <li class="nav-item ms-2">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn btn-auth btn-auth-logout">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item me-2">
        <a class="btn btn-auth btn-auth-login" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
    <li class="nav-item">
        <a class="btn btn-auth btn-auth-register" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
}
</ul>
