/* ===== SuperFoods Premium Dark Theme ===== */
:root {
  --sf-bg: #0a0a0a;
  --sf-bg-card: #141414;
  --sf-bg-card-hover: #1a1a1a;
  --sf-bg-surface: #0f0f0f;
  --sf-green: #00ff9c;
  --sf-green-dark: #00cc7a;
  --sf-green-light: #00ffd5;
  --sf-green-glow: rgba(0, 255, 156, 0.12);
  --sf-green-border: rgba(0, 255, 156, 0.25);
  --sf-text: #ffffff;
  --sf-text-muted: rgba(255, 255, 255, 0.6);
  --sf-gradient: linear-gradient(135deg, #00ff9c 0%, #00ffd5 100%);
  --sf-gradient-animated: linear-gradient(90deg, #00ff2a, #00ff9c, #00ffd5, #00ff9c, #00ff2a);
  --sf-radius: 16px;
  --sf-radius-lg: 24px;
  --sf-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  --sf-shadow-glow: 0 0 40px rgba(0, 255, 156, 0.15);
  --sf-transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

* {
  box-sizing: border-box;
}

html {
  font-size: 15px;
  position: relative;
  min-height: 100%;
  scroll-behavior: smooth;
}

@media (min-width: 768px) {
  html {
    font-size: 16px;
  }
}

body {
  background: var(--sf-bg);
  color: var(--sf-text);
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  line-height: 1.6;
  overflow-x: hidden;
}

/* ===== ANIMATIONS ===== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes glow {
  0%, 100% { box-shadow: 0 0 20px rgba(0, 255, 156, 0.2); }
  50% { box-shadow: 0 0 40px rgba(0, 255, 156, 0.4); }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

/* ===== NAVBAR ===== */
.navbar-sf {
  background: rgba(10, 10, 10, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 1rem 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  transition: var(--sf-transition);
}

.navbar-sf.scrolled {
  padding: 0.7rem 0;
  background: rgba(10, 10, 10, 0.95);
}

.navbar-sf .navbar-brand {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--sf-green) !important;
  letter-spacing: -0.02em;
  transition: var(--sf-transition);
}

.navbar-sf .navbar-brand .brand-icon {
  font-size: 1.3rem;
}

.navbar-sf .navbar-brand:hover {
  color: var(--sf-green-light) !important;
  transform: scale(1.02);
}

.navbar-sf .nav-link {
  color: rgba(255, 255, 255, 0.75) !important;
  font-size: 0.95rem;
  font-weight: 500;
  padding: 0.5rem 1rem !important;
  margin: 0 0.2rem;
  border-radius: 10px;
  transition: var(--sf-transition);
  position: relative;
}

.navbar-sf .nav-link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 0;
  height: 2px;
  background: var(--sf-gradient);
  transition: var(--sf-transition);
  transform: translateX(-50%);
}

.navbar-sf .nav-link:hover {
  color: #fff !important;
  background: rgba(255, 255, 255, 0.05);
}

.navbar-sf .nav-link:hover::after {
  width: 60%;
}

.navbar-sf .nav-link i {
  font-size: 1rem;
}

.navbar-sf .navbar-toggler {
  border: none;
  padding: 0.5rem;
}

.navbar-sf .navbar-toggler:focus {
  box-shadow: none;
}

/* ===== AUTH BUTTONS ===== */
.nav-auth {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.nav-auth .btn-auth {
  border-radius: 50px;
  padding: 0.5rem 1.5rem;
  font-weight: 600;
  font-size: 0.9rem;
  transition: var(--sf-transition);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
}

.btn-auth-login {
  color: #fff;
  border: 1.5px solid rgba(255, 255, 255, 0.25);
  background: transparent;
}

.btn-auth-login:hover {
  border-color: var(--sf-green);
  color: var(--sf-green);
  background: rgba(0, 255, 156, 0.05);
  transform: translateY(-2px);
}

.btn-auth-register {
  background: var(--sf-gradient);
  color: #000;
  border: none;
  font-weight: 700;
}

.btn-auth-register:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(0, 255, 156, 0.3);
  color: #000;
}

.btn-auth-logout {
  color: rgba(255, 255, 255, 0.7);
  border: none;
  background: transparent;
  padding: 0.5rem 1rem;
}

.btn-auth-logout:hover {
  color: var(--sf-green);
}

.nav-auth .greeting {
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
  font-size: 0.9rem;
}

/* ===== PAGE HERO ===== */
.page-hero {
  padding: 8rem 0 4rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.page-hero::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 150%;
  height: 100%;
  background: radial-gradient(ellipse at center top, rgba(0, 255, 156, 0.08) 0%, transparent 60%);
  pointer-events: none;
}

.page-hero h1 {
  font-size: 3rem;
  font-weight: 800;
  margin-bottom: 1rem;
  letter-spacing: -0.02em;
  animation: fadeInUp 0.8s ease-out;
}

@media (min-width: 768px) {
  .page-hero h1 {
    font-size: 4rem;
  }
}

.page-hero p {
  font-size: 1.2rem;
  color: var(--sf-text-muted);
  max-width: 600px;
  margin: 0 auto;
  animation: fadeInUp 0.8s ease-out 0.1s both;
}

/* ===== HERO SECTION (HOME) ===== */
.hero-section {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rem 1.5rem 4rem;
  position: relative;
  overflow: hidden;
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 30% 30%, rgba(0, 255, 156, 0.06) 0%, transparent 40%),
              radial-gradient(circle at 70% 70%, rgba(0, 255, 213, 0.04) 0%, transparent 40%);
  animation: float 20s ease-in-out infinite;
}

.hero-glass {
  position: relative;
  max-width: 800px;
  margin: 0 auto;
  padding: 4rem 3rem;
  border-radius: var(--sf-radius-lg);
  background: rgba(20, 20, 20, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.05);
  box-shadow: var(--sf-shadow);
  animation: fadeInUp 1s ease-out;
}

.hero-glass h1 {
  font-size: 2.8rem;
  font-weight: 800;
  line-height: 1.15;
  margin-bottom: 1.25rem;
  letter-spacing: -0.02em;
  background: linear-gradient(135deg, #fff 0%, rgba(255, 255, 255, 0.8) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

@media (min-width: 768px) {
  .hero-glass {
    padding: 5rem 4rem;
  }
  .hero-glass h1 {
    font-size: 4rem;
  }
}

.hero-glass p {
  font-size: 1.15rem;
  margin-bottom: 2rem;
  color: var(--sf-text-muted);
  line-height: 1.7;
}

.btn-sf-hero {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 1rem 2.5rem;
  border-radius: 50px;
  font-size: 1rem;
  font-weight: 700;
  color: #000;
  text-decoration: none;
  background: var(--sf-gradient-animated);
  background-size: 400% 100%;
  animation: gradientShift 8s linear infinite;
  transition: var(--sf-transition);
  box-shadow: 0 8px 30px rgba(0, 255, 156, 0.25);
}

.btn-sf-hero:hover {
  transform: translateY(-3px) scale(1.02);
  box-shadow: 0 15px 40px rgba(0, 255, 156, 0.35);
  color: #000;
}

/* ===== SECTION STYLES ===== */
.sf-section {
  padding: 5rem 0;
  position: relative;
}

.sf-section-title {
  text-align: center;
  margin-bottom: 3.5rem;
}

.sf-section-title h2 {
  font-size: 2.5rem;
  font-weight: 800;
  margin-bottom: 0.75rem;
  letter-spacing: -0.02em;
}

.sf-section-title p {
  font-size: 1.1rem;
  color: var(--sf-text-muted);
  max-width: 500px;
  margin: 0 auto;
}

/* ===== PRODUCT CARDS ===== */
.sf-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2rem;
}

.sf-card {
  background: var(--sf-bg-card);
  padding: 2rem;
  border-radius: var(--sf-radius);
  border: 1px solid rgba(255, 255, 255, 0.04);
  display: flex;
  flex-direction: column;
  gap: 1rem;
  box-shadow: var(--sf-shadow);
  transition: var(--sf-transition);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.sf-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: var(--sf-gradient);
  opacity: 0;
  transition: var(--sf-transition);
}

.sf-card:hover {
  transform: translateY(-8px);
  background: var(--sf-bg-card-hover);
  border-color: rgba(0, 255, 156, 0.1);
  box-shadow: var(--sf-shadow), var(--sf-shadow-glow);
}

.sf-card:hover::before {
  opacity: 1;
}

.sf-card-icon {
  font-size: 3rem;
  margin-bottom: 0.5rem;
  display: block;
}

.sf-card h3 {
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--sf-text);
  margin: 0;
}

.sf-card p {
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--sf-text-muted);
  flex-grow: 1;
}

.sf-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.6rem 1.5rem;
  font-weight: 600;
  border-radius: 50px;
  font-size: 0.85rem;
  background: rgba(0, 255, 156, 0.1);
  border: 1px solid var(--sf-green-border);
  color: var(--sf-green);
  margin-top: auto;
  transition: var(--sf-transition);
}

.sf-card:hover .sf-tag {
  background: rgba(0, 255, 156, 0.15);
}

/* Product card with image */
.sf-product-card {
  text-align: left;
}

.sf-product-card .product-image {
  width: 100%;
  height: 200px;
  object-fit: contain;
  border-radius: 12px;
  background: linear-gradient(135deg, rgba(0, 255, 156, 0.05) 0%, rgba(0, 0, 0, 0.2) 100%);
  padding: 1.5rem;
  margin-bottom: 0.5rem;
}

.sf-product-card .product-price {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--sf-green);
}

.sf-product-card .btn-buy {
  width: 100%;
  padding: 0.9rem;
  border-radius: 12px;
  background: var(--sf-gradient);
  color: #000;
  font-weight: 700;
  border: none;
  cursor: pointer;
  transition: var(--sf-transition);
  margin-top: 1rem;
}

.sf-product-card .btn-buy:hover {
  transform: scale(1.02);
  box-shadow: 0 8px 25px rgba(0, 255, 156, 0.3);
}

/* ===== BENEFITS SECTION ===== */
.sf-benefits {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 2rem;
  padding: 4rem 0;
}

.sf-benefit {
  text-align: center;
  padding: 2rem 1.5rem;
  border-radius: var(--sf-radius);
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.03);
  transition: var(--sf-transition);
}

.sf-benefit:hover {
  background: rgba(0, 255, 156, 0.03);
  border-color: var(--sf-green-border);
}

.sf-benefit-icon {
  width: 60px;
  height: 60px;
  margin: 0 auto 1rem;
  border-radius: 50%;
  background: rgba(0, 255, 156, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  color: var(--sf-green);
}

.sf-benefit h4 {
  color: var(--sf-green);
  font-weight: 700;
  font-size: 1.1rem;
  margin-bottom: 0.5rem;
}

.sf-benefit p {
  color: var(--sf-text-muted);
  font-size: 0.95rem;
}

/* ===== CONTACT SECTION ===== */
.contact-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
}

@media (min-width: 768px) {
  .contact-grid {
    grid-template-columns: 1fr 1fr;
  }
}

.contact-info {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.contact-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1.5rem;
  background: var(--sf-bg-card);
  border-radius: var(--sf-radius);
  border: 1px solid rgba(255, 255, 255, 0.04);
  transition: var(--sf-transition);
}

.contact-item:hover {
  border-color: var(--sf-green-border);
  transform: translateX(5px);
}

.contact-item-icon {
  width: 50px;
  height: 50px;
  border-radius: 12px;
  background: rgba(0, 255, 156, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--sf-green);
  font-size: 1.3rem;
  flex-shrink: 0;
}

.contact-item h5 {
  font-weight: 600;
  margin-bottom: 0.25rem;
  color: var(--sf-text);
}

.contact-item p {
  color: var(--sf-text-muted);
  margin: 0;
  font-size: 0.95rem;
}

.contact-form {
  background: var(--sf-bg-card);
  padding: 2.5rem;
  border-radius: var(--sf-radius-lg);
  border: 1px