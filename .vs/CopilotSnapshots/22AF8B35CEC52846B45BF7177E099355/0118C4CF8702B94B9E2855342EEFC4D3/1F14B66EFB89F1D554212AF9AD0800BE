@model IEnumerable<ASP_Foods2.Data.Product>

@{
    ViewData["Title"] = "Управление на продукти";
}

<div class="page-hero" style="padding-bottom: 2rem;">
    <div class="container">
        <h1><i class="bi bi-box-seam me-3"></i>Управление на <span class="text-gradient">Продукти</span></h1>
        <p>Преглед, редактиране и изтриване на продукти в магазина</p>
    </div>
</div>

<div class="container">
    <div class="admin-toolbar">
        <div class="admin-toolbar-left">
            <span class="admin-count">
                <i class="bi bi-archive me-2"></i>@Model.Count() продукта
            </span>
        </div>
        <div class="admin-toolbar-right">
            <a asp-action="Create" class="btn-admin-primary">
                <i class="bi bi-plus-lg me-2"></i>Добави продукт
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="admin-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Продукт</th>
                        <th>Категория</th>
                        <th>Марка</th>
                        <th>Количество</th>
                        <th>Цена</th>
                        <th>Добавен</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="product-cell">
                                    <div class="product-cell-icon">🌿</div>
                                    <div class="product-cell-info">
                                        <span class="product-cell-name">@item.Name</span>
                                        <span class="product-cell-sku">@item.CatalogId</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge-category">@item.Categories?.Name</span>
                            </td>
                            <td>@item.Brands?.Name</td>
                            <td>
                                <span class="@(item.Quantity > 0 ? "text-success" : "text-danger")">
                                    @item.Quantity @item.Units?.Name
                                </span>
                            </td>
                            <td>
                                <span class="price-cell">@item.Price.ToString("F2") лв</span>
                            </td>
                            <td>
                                <span class="date-cell">@item.DateAdded.ToString("dd.MM.yyyy")</span>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn action-btn-edit" title="Редактирай">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="action-btn action-btn-view" title="Преглед">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn action-btn-delete" title="Изтрий">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-inbox"></i>
            </div>
            <h3>Няма добавени продукти</h3>
            <p>Започнете като добавите първия продукт в магазина.</p>
            <a asp-action="Create" class="btn-sf-hero" style="margin-top: 1.5rem;">
                <i class="bi bi-plus-lg me-2"></i>Добави първи продукт
            </a>
        </div>
    }

    <div class="admin-back-link">
        <a asp-controller="Home" asp-action="Products">
            <i class="bi bi-arrow-left me-2"></i>Назад към магазина
        </a>
    </div>
</div>

<style>
    .admin-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding: 1rem 1.5rem;
        background: var(--sf-bg-card);
        border-radius: var(--sf-radius);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .admin-count {
        color: var(--sf-text-muted);
        font-weight: 500;
    }

    .admin-table-wrapper {
        background: var(--sf-bg-card);
        border-radius: var(--sf-radius-lg);
        border: 1px solid rgba(255, 255, 255, 0.05);
        overflow: hidden;
        margin-bottom: 2rem;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

    .admin-table thead {
        background: rgba(0, 0, 0, 0.3);
    }

    .admin-table th {
        padding: 1rem 1.25rem;
        text-align: left;
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--sf-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .admin-table td {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        vertical-align: middle;
    }

    .admin-table tbody tr {
        transition: var(--sf-transition);
    }

    .admin-table tbody tr:hover {
        background: rgba(0, 255, 156, 0.02);
    }

    .admin-table tbody tr:last-child td {
        border-bottom: none;
    }

    .product-cell {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .product-cell-icon {
        width: 45px;
        height: 45px;
        border-radius: 10px;
        background: rgba(0, 255, 156, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }

    .product-cell-info {
        display: flex;
        flex-direction: column;
    }

    .product-cell-name {
        font-weight: 600;
        color: var(--sf-text);
    }

    .product-cell-sku {
        font-size: 0.8rem;
        color: var(--sf-text-muted);
    }

    .badge-category {
        padding: 0.35rem 0.75rem;
        border-radius: 20px;
        background: rgba(0, 255, 156, 0.1);
        color: var(--sf-green);
        font-size: 0.8rem;
        font-weight: 500;
    }

    .price-cell {
        font-weight: 700;
        color: var(--sf-green);
    }

    .date-cell {
        color: var(--sf-text-muted);
        font-size: 0.9rem;
    }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
    }

    .action-btn {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: var(--sf-transition);
    }

    .action-btn-edit {
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
    }

    .action-btn-edit:hover {
        background: rgba(59, 130, 246, 0.2);
        color: #3b82f6;
    }

    .action-btn-view {
        background: rgba(0, 255, 156, 0.1);
        color: var(--sf-green);
    }

    .action-btn-view:hover {
        background: rgba(0, 255, 156, 0.2);
        color: var(--sf-green);
    }

    .action-btn-delete {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }

    .action-btn-delete:hover {
        background: rgba(239, 68, 68, 0.2);
        color: #ef4444;
    }

    .btn-admin-primary {
        display: inline-flex;
        align-items: center;
        padding: 0.75rem 1.5rem;
        border-radius: 10px;
        background: var(--sf-gradient);
        color: #000;
        font-weight: 700;
        font-size: 0.95rem;
        text-decoration: none;
        transition: var(--sf-transition);
    }

    .btn-admin-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(0, 255, 156, 0.3);
        color: #000;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: var(--sf-bg-card);
        border-radius: var(--sf-radius-lg);
        border: 1px solid rgba(255, 255, 255, 0.04);
    }

    .empty-state-icon {
        font-size: 4rem;
        color: var(--sf-text-muted);
        margin-bottom: 1.5rem;
    }

    .empty-state h3 {
        color: var(--sf-text);
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: var(--sf-text-muted);
    }

    .admin-back-link {
        text-align: center;
        margin-top: 2rem;
    }

    .admin-back-link a {
        color: var(--sf-text-muted);
        text-decoration: none;
        font-weight: 500;
        transition: var(--sf-transition);
    }

    .admin-back-link a:hover {
        color: var(--sf-green);
    }

    .text-success {
        color: var(--sf-green) !important;
    }

    .text-danger {
        color: #ef4444 !important;
    }

    @@media (max-width: 992px) {
        .admin-table-wrapper {
            overflow-x: auto;
        }

        .admin-table {
            min-width: 800px;
        }
    }
</style>
