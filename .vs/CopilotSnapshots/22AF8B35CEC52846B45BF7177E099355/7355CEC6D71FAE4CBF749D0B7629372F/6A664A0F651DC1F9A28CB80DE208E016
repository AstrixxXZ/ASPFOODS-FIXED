@{
    Layout = "/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Управление на акаунта";
}

<div class="page-hero" style="padding-bottom: 2rem;">
    <div class="container">
        <h1><i class="bi bi-person-gear me-3"></i>Настройки на <span class="text-gradient">Акаунта</span></h1>
        <p>Управлявайте вашия профил и настройки за сигурност</p>
    </div>
</div>

<div class="container">
    <div class="row">
        <div class="col-lg-3 mb-4">
            <partial name="_ManageNav" />
        </div>
        <div class="col-lg-9">
            <div class="manage-content-card">
                @RenderBody()
            </div>
        </div>
    </div>
</div>

<style>
    .manage-content-card {
        background: var(--sf-bg-card);
        border-radius: var(--sf-radius-lg);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 2rem;
    }

    .manage-content-card h2, 
    .manage-content-card h3,
    .manage-content-card h4 {
        color: var(--sf-text);
        font-weight: 700;
    }

    .manage-content-card .form-label {
        color: var(--sf-text-muted);
        font-weight: 500;
        font-size: 0.9rem;
    }

    .manage-content-card .form-control {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        border-radius: 10px;
        padding: 0.75rem 1rem;
    }

    .manage-content-card .form-control:focus {
        background: rgba(255, 255, 255, 0.05);
        border-color: var(--sf-green);
        box-shadow: 0 0 0 3px rgba(0, 255, 156, 0.1);
        color: #fff;
    }

    .manage-content-card .form-control:disabled,
    .manage-content-card .form-control[readonly] {
        background: rgba(255, 255, 255, 0.02);
        color: var(--sf-text-muted);
    }

    .manage-content-card .btn-primary {
        background: var(--sf-gradient);
        border: none;
        color: #000;
        font-weight: 700;
        padding: 0.75rem 2rem;
        border-radius: 10px;
        transition: var(--sf-transition);
    }

    .manage-content-card .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(0, 255, 156, 0.3);
    }

    .manage-content-card .text-danger {
        color: #ef4444 !important;
    }

    .manage-content-card a {
        color: var(--sf-green);
    }

    .manage-content-card a:hover {
        color: var(--sf-green-light);
    }

    .manage-content-card p {
        color: var(--sf-text-muted);
    }

    .manage-content-card dl {
        color: var(--sf-text);
    }

    .manage-content-card dt {
        color: var(--sf-text-muted);
        font-weight: 500;
    }

    .manage-content-card .alert-success {
        background: rgba(0, 255, 156, 0.1);
        border: 1px solid rgba(0, 255, 156, 0.3);
        color: var(--sf-green);
    }

    .manage-content-card .alert-danger {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #ef4444;
    }
</style>

@RenderSection("Scripts", required: false)
