@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Лични данни";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="profile-header">
    <h3><i class="bi bi-database me-2"></i>Лични данни</h3>
    <p>Управление и изтегляне на вашите лични данни</p>
</div>

<div class="personal-data-section">
    <div class="data-card">
        <div class="data-card-icon download">
            <i class="bi bi-download"></i>
        </div>
        <div class="data-card-content">
            <h5>Изтеглете данните си</h5>
            <p>Изтеглете копие на всички лични данни, които съхраняваме за вас.</p>
            <form asp-page="./DownloadPersonalData" method="post" class="mt-3">
                <button type="submit" class="btn-download">
                    <i class="bi bi-cloud-download me-2"></i>Изтегли данните
                </button>
            </form>
        </div>
    </div>

    <div class="data-card danger">
        <div class="data-card-icon delete">
            <i class="bi bi-trash3"></i>
        </div>
        <div class="data-card-content">
            <h5>Изтриване на акаунт</h5>
            <p>Изтрийте завинаги вашия акаунт и всички свързани данни. Това действие не може да бъде отменено!</p>
            <a asp-page="./DeletePersonalData" class="btn-delete mt-3">
                <i class="bi bi-exclamation-triangle me-2"></i>Изтрий акаунта
            </a>
        </div>
    </div>
</div>

<style>
    .profile-header {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .profile-header h3 {
        margin: 0;
        color: var(--sf-text);
        font-weight: 700;
    }

    .profile-header p {
        margin: 0.5rem 0 0;
        color: var(--sf-text-muted);
        font-size: 0.95rem;
    }

    .personal-data-section {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .data-card {
        display: flex;
        gap: 1.5rem;
        padding: 1.5rem;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        transition: var(--sf-transition);
    }

    .data-card:hover {
        border-color: rgba(255, 255, 255, 0.1);
    }

    .data-card.danger {
        border-color: rgba(239, 68, 68, 0.2);
    }

    .data-card.danger:hover {
        border-color: rgba(239, 68, 68, 0.3);
    }

    .data-card-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    .data-card-icon.download {
        background: rgba(0, 255, 156, 0.1);
        color: var(--sf-green);
    }

    .data-card-icon.delete {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }

    .data-card-content {
        flex: 1;
    }

    .data-card-content h5 {
        margin: 0 0 0.5rem;
        color: var(--sf-text);
        font-weight: 600;
    }

    .data-card-content p {
        margin: 0;
        color: var(--sf-text-muted);
        font-size: 0.9rem;
    }

    .btn-download {
        display: inline-flex;
        align-items: center;
        padding: 0.6rem 1.25rem;
        border-radius: 8px;
        background: var(--sf-gradient);
        color: #000;
        font-weight: 600;
        font-size: 0.9rem;
        border: none;
        cursor: pointer;
        transition: var(--sf-transition);
        text-decoration: none;
    }

    .btn-download:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(0, 255, 156, 0.3);
        color: #000;
    }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        padding: 0.6rem 1.25rem;
        border-radius: 8px;
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        font-weight: 600;
        font-size: 0.9rem;
        border: 1px solid rgba(239, 68, 68, 0.3);
        cursor: pointer;
        transition: var(--sf-transition);
        text-decoration: none;
    }

    .btn-delete:hover {
        background: rgba(239, 68, 68, 0.2);
        color: #ef4444;
    }
</style>
