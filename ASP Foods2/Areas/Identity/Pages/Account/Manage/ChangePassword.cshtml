@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Промяна на парола";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="profile-header">
    <h3><i class="bi bi-key me-2"></i>Промяна на парола</h3>
    <p>Сменете паролата за вашия акаунт</p>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<form id="change-password-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
    
    <div class="mb-4">
        <label asp-for="Input.OldPassword" class="form-label">Текуща парола</label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input asp-for="Input.OldPassword" class="form-control" placeholder="Въведете текущата парола" />
        </div>
        <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
    </div>

    <div class="mb-4">
        <label asp-for="Input.NewPassword" class="form-label">Нова парола</label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-key"></i></span>
            <input asp-for="Input.NewPassword" class="form-control" placeholder="Въведете новата парола" />
        </div>
        <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
    </div>

    <div class="mb-4">
        <label asp-for="Input.ConfirmPassword" class="form-label">Потвърдете паролата</label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
            <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="Потвърдете новата парола" />
        </div>
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn btn-primary">
        <i class="bi bi-check-lg me-2"></i>Промени паролата
    </button>
</form>

<style>
    .profile-header {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .profile-header h3 {
        margin: 0;
        color: var(--sf-text);
        font-weight: 700;
    }

    .profile-header p {
        margin: 0.5rem 0 0;
        color: var(--sf-text-muted);
        font-size: 0.95rem;
    }

    .input-group-text {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--sf-green);
        border-radius: 10px 0 0 10px;
    }

    .input-group .form-control {
        border-radius: 0 10px 10px 0;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
