@{
    Layout = "/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Настройки на профила";
}

<div class="page-hero compact-page-hero manage-page-hero">
    <div class="container">
        <h1><i class="bi bi-person-gear me-2"></i>Настройки на <span class="text-gradient">профила</span></h1>
        <p>Управлявай профила, имейла, паролата и личните си данни.</p>
    </div>
</div>

<div class="container manage-page">
    <div class="manage-shell">
        <div>
            <partial name="_ManageNav" />
        </div>
        <div class="manage-content-card">
            @RenderBody()
        </div>
    </div>
</div>

<style>
    .manage-page { padding-bottom: 2.5rem; }
    .manage-shell { display: grid; grid-template-columns: minmax(220px, 0.32fr) minmax(0, 1fr); gap: 0.9rem; align-items: start; }
    .manage-content-card { background: var(--sf-bg-card); border-radius: 8px; border: 1px solid rgba(255,255,255,.05); padding: 1rem; box-shadow: 0 14px 32px rgba(0,0,0,.32); }
    .manage-content-card h2,
    .manage-content-card h3,
    .manage-content-card h4 { color: var(--sf-text); font-weight: 700; }
    .manage-content-card .form-label { color: var(--sf-text-muted); font-weight: 500; font-size: 0.82rem; margin-bottom: 0.3rem; }
    .manage-content-card .form-control { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.1); color: #fff; border-radius: 8px; padding: 0.62rem 0.75rem; font-size: 0.9rem; }
    .manage-content-card .form-control:focus { background: rgba(255,255,255,.05); border-color: var(--sf-green); box-shadow: 0 0 0 3px rgba(0,255,156,.1); color: #fff; }
    .manage-content-card .form-control:disabled,
    .manage-content-card .form-control[readonly] { background: rgba(255,255,255,.02); color: var(--sf-text-muted); }
    .manage-content-card .btn-primary { background: var(--sf-gradient); border: none; color: #000; font-weight: 700; padding: 0.65rem 1rem; border-radius: 8px; transition: var(--sf-transition); }
    .manage-content-card .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(0,255,156,.22); color: #000; }
    .manage-content-card .text-danger { color: #ef4444 !important; }
    .manage-content-card a { color: var(--sf-green); }
    .manage-content-card a:hover { color: var(--sf-green-light); }
    .manage-content-card p { color: var(--sf-text-muted); }
    .manage-content-card dl { color: var(--sf-text); }
    .manage-content-card dt { color: var(--sf-text-muted); font-weight: 500; }
    .manage-content-card .alert-success { background: rgba(0,255,156,.1); border: 1px solid rgba(0,255,156,.3); color: var(--sf-green); }
    .manage-content-card .alert-danger { background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.3); color: #ef4444; }
    @@media (max-width: 991px) { .manage-shell { grid-template-columns: 1fr; } }
</style>

@RenderSection("Scripts", required: false)
