@page
@model EmailModel
@{
    ViewData["Title"] = "Управление на имейл";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<div class="profile-header">
    <h3><i class="bi bi-envelope me-2"></i>Имейл</h3>
    <p>Управление на имейл адреса за вашия акаунт</p>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<form id="email-form" method="post">
    <div asp-validation-summary="All" class="text-danger mb-3" role="alert"></div>
    
    <div class="mb-4">
        <label asp-for="Email" class="form-label">Текущ имейл</label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input asp-for="Email" class="form-control" disabled />
            @if (Model.IsEmailConfirmed)
            {
                <span class="input-group-text" style="background: rgba(0, 255, 156, 0.1); color: var(--sf-green); border-color: rgba(0, 255, 156, 0.3);">
                    <i class="bi bi-check-circle me-1"></i> Потвърден
                </span>
            }
            else
            {
                <span class="input-group-text" style="background: rgba(255, 193, 7, 0.1); color: #ffc107; border-color: rgba(255, 193, 7, 0.3);">
                    <i class="bi bi-exclamation-circle me-1"></i> Непотвърден
                </span>
            }
        </div>
    </div>

    <div class="mb-4">
        <label asp-for="Input.NewEmail" class="form-label">Нов имейл</label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope-plus"></i></span>
            <input asp-for="Input.NewEmail" class="form-control" placeholder="Въведете нов имейл адрес" />
        </div>
        <span asp-validation-for="Input.NewEmail" class="text-danger small"></span>
    </div>

    <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail" class="btn btn-primary">
        <i class="bi bi-check-lg me-2"></i>Промени имейла
    </button>
</form>

<style>
    .profile-header {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .profile-header h3 {
        margin: 0;
        color: var(--sf-text);
        font-weight: 700;
    }

    .profile-header p {
        margin: 0.5rem 0 0;
        color: var(--sf-text-muted);
        font-size: 0.95rem;
    }

    .input-group-text {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--sf-green);
    }

    .input-group-text:first-child {
        border-radius: 10px 0 0 10px;
    }

    .input-group-text:last-child {
        border-radius: 0 10px 10px 0;
    }

    .input-group .form-control {
        border-radius: 0;
    }

    .input-group .form-control:last-child {
        border-radius: 0 10px 10px 0;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
