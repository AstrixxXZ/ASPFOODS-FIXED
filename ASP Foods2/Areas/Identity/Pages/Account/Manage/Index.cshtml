@page
@model IndexModel
@{
    ViewData["Title"] = "Профил";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="profile-header">
    <h3><i class="bi bi-person-circle me-2"></i>Профил</h3>
    <p>Управление на вашата профилна информация</p>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<form id="profile-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
    
    <div class="mb-4">
        <label asp-for="Username" class="form-label">Потребителско име</label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-person"></i></span>
            <input asp-for="Username" class="form-control" disabled />
        </div>
    </div>

    <div class="mb-4">
        <label asp-for="Input.PhoneNumber" class="form-label">Телефонен номер</label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-telephone"></i></span>
            <input asp-for="Input.PhoneNumber" class="form-control" placeholder="+359 888 123 456" />
        </div>
        <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
    </div>

    <button id="update-profile-button" type="submit" class="btn btn-primary">
        <i class="bi bi-check-lg me-2"></i>Запази промените
    </button>
</form>

<style>
    .profile-header {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .profile-header h3 {
        margin: 0;
        color: var(--sf-text);
        font-weight: 700;
    }

    .profile-header p {
        margin: 0.5rem 0 0;
        color: var(--sf-text-muted);
        font-size: 0.95rem;
    }

    .input-group-text {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--sf-green);
        border-radius: 10px 0 0 10px;
    }

    .input-group .form-control {
        border-radius: 0 10px 10px 0;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
