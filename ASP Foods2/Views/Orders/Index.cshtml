@model IEnumerable<ASP_Foods2.Data.Order>
@using System.Linq

@{
    var orders = (Model ?? Enumerable.Empty<ASP_Foods2.Data.Order>())
        .OrderByDescending(order => order.DateAdded)
        .ToList();

    ViewData["Title"] = "Поръчки";

    var totalQuantity = orders.Sum(order => order.Quantity);
    var totalRevenue = orders.Sum(order =>
    {
        var unitPrice = order.UnitPrice > 0m ? order.UnitPrice : order.Products?.Price ?? 0m;
        var subtotal = unitPrice * order.Quantity;
        return Math.Max(subtotal - order.DiscountAmount, 0m);
    });
    var uniqueClients = orders
        .Select(order => order.ClientId)
        .Where(clientId => !string.IsNullOrWhiteSpace(clientId))
        .Distinct()
        .Count();

    string GetClientName(ASP_Foods2.Data.Order order)
    {
        var client = order.Clients;
        if (client == null)
        {
            return "Непознат клиент";
        }

        if (!string.IsNullOrWhiteSpace(client.FirstName) || !string.IsNullOrWhiteSpace(client.LastName))
        {
            return $"{client.FirstName} {client.LastName}".Trim();
        }

        return client.Email ?? client.UserName ?? "Клиент";
    }
}

<section class="orders-admin-page">
    <div class="container">
        <div class="orders-admin-hero">
            <div class="orders-admin-hero__content">
                <span class="orders-admin-eyebrow">
                    <i class="bi bi-receipt-cutoff"></i>
                    Управление на поръчките
                </span>
                <h1>По-ясен изглед за всички поръчки в магазина</h1>
                <p>
                    Следи клиентите, избраните продукти и количествата в една подредена администраторска страница,
                    без сурови ID стойности и без стария scaffold вид.
                </p>
            </div>

            <div class="orders-admin-hero__panel">
                <span>Последно обновяване</span>
                <strong>@(orders.FirstOrDefault()?.DateAdded.ToString("dd.MM.yyyy HH:mm") ?? "Няма данни")</strong>
                <p>Показваме най-новите поръчки най-отгоре за по-бърза реакция.</p>
            </div>
        </div>

        <div class="orders-admin-stats">
            <article class="orders-admin-stat">
                <span class="orders-admin-stat__icon"><i class="bi bi-receipt"></i></span>
                <div>
                    <span class="orders-admin-stat__label">Всички поръчки</span>
                    <strong>@orders.Count</strong>
                </div>
            </article>

            <article class="orders-admin-stat">
                <span class="orders-admin-stat__icon"><i class="bi bi-people"></i></span>
                <div>
                    <span class="orders-admin-stat__label">Уникални клиенти</span>
                    <strong>@uniqueClients</strong>
                </div>
            </article>

            <article class="orders-admin-stat">
                <span class="orders-admin-stat__icon"><i class="bi bi-box2-heart"></i></span>
                <div>
                    <span class="orders-admin-stat__label">Поръчани бройки</span>
                    <strong>@totalQuantity</strong>
                </div>
            </article>

            <article class="orders-admin-stat">
                <span class="orders-admin-stat__icon"><i class="bi bi-cash-stack"></i></span>
                <div>
                    <span class="orders-admin-stat__label">Общ оборот</span>
                    <strong>@totalRevenue.ToString("0.00") лв.</strong>
                </div>
            </article>
        </div>

        <div class="orders-admin-toolbar">
            <div class="orders-admin-toolbar__meta">
                <span class="orders-admin-toolbar__badge">
                    <i class="bi bi-shield-lock"></i>
                    Само за администратор
                </span>
                <p>Преглед на всички записи с бърз достъп до детайли, редакция и изтриване.</p>
            </div>

            <a asp-controller="Admin" asp-action="Index" class="orders-admin-toolbar__link">
                <i class="bi bi-arrow-left"></i>
                Към админ панела
            </a>
        </div>

        @if (orders.Any())
        {
            <div class="orders-admin-table-wrap">
                <table class="orders-admin-table">
                    <thead>
                        <tr>
                            <th>Клиент</th>
                            <th>Продукт</th>
                            <th>Количество</th>
                            <th>Дата</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in orders)
                        {
                            <tr>
                                <td>
                                    <div class="orders-admin-person">
                                        <span class="orders-admin-person__avatar">
                                            @GetClientName(item).Substring(0, 1).ToUpperInvariant()
                                        </span>
                                        <div>
                                            <strong>@GetClientName(item)</strong>
                                            <span>@(item.Clients?.Email ?? "Без имейл")</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="orders-admin-product">

                                        @{
                                            var productIdString = item.Products?.Id.ToString();
                                        }

                                        @if (item.Products != null && !string.IsNullOrWhiteSpace(productIdString))
                                        {
                                            <img src="@($"/images/products/{productIdString}.jpg")"
                                                 alt="@item.Products?.Name"
                                                 class="orders-admin-product__image" />
                                        }
                                        else
                                        {
                                            <span class="orders-admin-product__placeholder">
                                                <i class="bi bi-image"></i>
                                            </span>
                                        }

                                        <div>
                                            <strong>@(item.Products?.Name ?? "Продукт")</strong>
                                            <span>@(string.IsNullOrWhiteSpace(item.Products?.CatalogId) ? "Без код" : item.Products.CatalogId)</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="orders-admin-quantity">@item.Quantity бр.</span>
                                </td>
                                <td>
                                    <div class="orders-admin-date">
                                        <strong>@item.DateAdded.ToString("dd.MM.yyyy")</strong>
                                        <span>@item.DateAdded.ToString("HH:mm")</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="orders-admin-actions">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="orders-admin-action orders-admin-action--view" title="Детайли">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="orders-admin-action orders-admin-action--edit" title="Редакция">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="orders-admin-action orders-admin-action--delete" title="Изтрий">
                                            <i class="bi bi-trash3"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="orders-admin-empty">
                <div class="orders-admin-empty__icon">
                    <i class="bi bi-inbox"></i>
                </div>
                <h2>Все още няма направени поръчки</h2>
                <p>Когато потребителите потвърдят количката си, тук ще виждаш всяка поръчка на едно място.</p>
                <a asp-controller="Admin" asp-action="Index" class="orders-admin-toolbar__link">
                    <i class="bi bi-speedometer2"></i>
                    Обратно към панела
                </a>
            </div>
        }
    </div>
</section>
