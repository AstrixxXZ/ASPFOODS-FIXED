@model ASP_Foods2.Data.Order

@{
    ViewData["Title"] = "Детайли за поръчка";

    var client = Model.Clients;
    var product = Model.Products;
    var clientName = client == null
        ? "Непознат клиент"
        : string.IsNullOrWhiteSpace(client.FirstName) && string.IsNullOrWhiteSpace(client.LastName)
            ? client.Email ?? client.UserName ?? "Клиент"
            : $"{client.FirstName} {client.LastName}".Trim();
    var clientEmail = client?.Email ?? "Без имейл";
    var productName = product?.Name ?? "Продукт";
    var catalogId = string.IsNullOrWhiteSpace(product?.CatalogId) ? "Без код" : product.CatalogId;
    var unitPrice = Model.UnitPrice > 0m ? Model.UnitPrice : product?.Price ?? 0m;
    var subtotalPrice = unitPrice * Model.Quantity;
    var totalPrice = Math.Max(subtotalPrice - Model.DiscountAmount, 0m);
}

<section class="order-edit-page order-details-page">
    <div class="container">
        <div class="order-edit-hero">
            <div class="order-edit-hero__content">
                <a asp-action="Index" class="order-edit-back">
                    <i class="bi bi-arrow-left"></i>
                    <span>Към поръчките</span>
                </a>

                <span class="order-edit-eyebrow">
                    <i class="bi bi-eye"></i>
                    Детайли за поръчка
                </span>
                <h1>Поръчка #@Model.Id</h1>
                <p>Пълен преглед на клиента, продукта, количеството и стойността преди следваща админ стъпка.</p>
            </div>

            <div class="order-edit-hero__panel">
                <span class="order-edit-hero__label">Създадена на</span>
                <strong>Активна</strong>
                <time datetime="@Model.DateAdded.ToString("O")">@Model.DateAdded.ToString("dd.MM.yyyy HH:mm")</time>
            </div>
        </div>

        <div class="order-details-layout">
            <section class="order-edit-card order-details-main" aria-label="Основни детайли за поръчката">
                <div class="order-edit-card__header">
                    <div>
                        <span class="order-edit-card__eyebrow">Обобщение</span>
                        <h2>@productName</h2>
                    </div>
                    <span class="order-edit-card__badge">
                        <i class="bi bi-receipt"></i>
                        #@Model.Id
                    </span>
                </div>

                <div class="order-details-product__media">

                    @{
                        var productIdString = product?.Id.ToString();
                    }

                    @if (product != null && !string.IsNullOrWhiteSpace(productIdString))
                    {
                        <img src="@($"/images/products/{productIdString}.jpg")"
                             alt="@productName" />
                    }
                    else
                    {
                        <i class="bi bi-box2-heart"></i>
                    }

                </div>

                    <div class="order-details-product__content">
                        <span class="order-details-kicker">Продукт</span>
                        <h3>@productName</h3>
                        <p>@catalogId</p>
                    </div>
                </div>

                <div class="order-details-stats">
                    <article class="order-details-stat">
                        <span><i class="bi bi-layers"></i> Количество</span>
                        <strong>@Model.Quantity бр.</strong>
                    </article>
                    <article class="order-details-stat">
                        <span><i class="bi bi-tag"></i> Цена</span>
                        <strong>@unitPrice.ToString("0.00") лв.</strong>
                    </article>
                    @if (Model.DiscountAmount > 0)
                    {
                        <article class="order-details-stat">
                            <span><i class="bi bi-ticket-perforated"></i> Отстъпка</span>
                            <strong>-@Model.DiscountAmount.ToString("0.00") лв.</strong>
                        </article>
                    }
                    <article class="order-details-stat order-details-stat--total">
                        <span><i class="bi bi-cash-coin"></i> Общо</span>
                        <strong>@totalPrice.ToString("0.00") лв.</strong>
                    </article>
                </div>

                <div class="order-edit-actions">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="order-edit-btn order-edit-btn--primary">
                        <i class="bi bi-pencil-square"></i>
                        <span>Редактирай</span>
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="order-edit-btn order-edit-btn--danger">
                        <i class="bi bi-trash3"></i>
                        <span>Изтрий</span>
                    </a>
                    <a asp-action="Index" class="order-edit-btn order-edit-btn--ghost">
                        <i class="bi bi-arrow-left"></i>
                        <span>Назад</span>
                    </a>
                </div>
            </section>

            <aside class="order-edit-summary order-details-side" aria-label="Клиент и времева линия">
                <div class="order-edit-summary__header">
                    <span class="order-edit-summary__icon">
                        <i class="bi bi-person-vcard"></i>
                    </span>
                    <div>
                        <span>Клиент</span>
                        <strong>@clientName</strong>
                    </div>
                </div>

                <div class="order-edit-summary__list">
                    <div class="order-edit-summary__item">
                        <span><i class="bi bi-envelope"></i> Имейл</span>
                        <strong>@clientEmail</strong>
                    </div>
                    <div class="order-edit-summary__item">
                        <span><i class="bi bi-calendar2-week"></i> Дата</span>
                        <strong>@Model.DateAdded.ToString("dd.MM.yyyy")</strong>
                    </div>
                    <div class="order-edit-summary__item">
                        <span><i class="bi bi-clock"></i> Час</span>
                        <strong>@Model.DateAdded.ToString("HH:mm")</strong>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.PromoCode))
                    {
                        <div class="order-edit-summary__item">
                            <span><i class="bi bi-ticket-perforated"></i> Промокод</span>
                            <strong>@Model.PromoCode (@Model.DiscountPercent.ToString("0.##")%)</strong>
                        </div>
                    }
                </div>

                <div class="order-details-timeline">
                    <span class="order-details-kicker">Статус</span>
                    <div class="order-details-timeline__item">
                        <span></span>
                        <div>
                            <strong>Поръчката е записана</strong>
                            <p>@Model.DateAdded.ToString("dd.MM.yyyy HH:mm")</p>
                        </div>
                    </div>
                    <div class="order-details-timeline__item">
                        <span></span>
                        <div>
                            <strong>Готова за обработка</strong>
                            <p>Очаква действие от администратор.</p>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</section>
