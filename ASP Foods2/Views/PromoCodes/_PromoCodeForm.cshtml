@model ASP_Foods2.Data.PromoCode

@{
    var isEdit = Model.Id > 0;
}

<section class="promo-form-page">
    <div class="container">
        <div class="promo-form-card">
            <div class="promo-form-card__header">
                <div>
                    <span class="promo-form-card__eyebrow">
                        <i class="bi bi-ticket-perforated"></i>
                        @(isEdit ? "Редакция" : "Нов код")
                    </span>
                    <h1>@(isEdit ? "Редакция на промокод" : "Създай промокод")</h1>
                </div>
                <a asp-action="Index" class="promo-form-card__back">Назад</a>
            </div>

            <form asp-action="@(isEdit ? "Edit" : "Create")" method="post" class="promo-form-grid">
                @Html.AntiForgeryToken()
                @if (isEdit)
                {
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <input type="hidden" asp-for="UsedCount" />
                }

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <label class="promo-form-field">
                    <span>Код</span>
                    <input asp-for="Code" placeholder="WELCOME10" />
                    <span asp-validation-for="Code" class="text-danger"></span>
                </label>

                <label class="promo-form-field">
                    <span>Отстъпка (%)</span>
                    <input asp-for="DiscountPercent" type="number" step="0.01" min="0.01" max="100" />
                    <span asp-validation-for="DiscountPercent" class="text-danger"></span>
                </label>

                <label class="promo-form-field promo-form-field--full">
                    <span>Описание</span>
                    <input asp-for="Description" placeholder="Пролетна кампания за нови клиенти" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </label>

                <label class="promo-form-field">
                    <span>Минимална сума</span>
                    <input asp-for="MinimumOrderAmount" type="number" step="0.01" min="0" />
                    <span asp-validation-for="MinimumOrderAmount" class="text-danger"></span>
                </label>

                <label class="promo-form-field">
                    <span>Лимит използвания</span>
                    <input asp-for="UsageLimit" type="number" min="1" />
                    <span asp-validation-for="UsageLimit" class="text-danger"></span>
                </label>

                <label class="promo-form-field">
                    <span>Начална дата</span>
                    <input asp-for="ValidFrom" type="datetime-local" value="@(Model.ValidFrom?.ToString("yyyy-MM-ddTHH:mm"))" />
                    <span asp-validation-for="ValidFrom" class="text-danger"></span>
                </label>

                <label class="promo-form-field">
                    <span>Крайна дата</span>
                    <input asp-for="ValidTo" type="datetime-local" value="@(Model.ValidTo?.ToString("yyyy-MM-ddTHH:mm"))" />
                    <span asp-validation-for="ValidTo" class="text-danger"></span>
                </label>

                <label class="promo-form-switch promo-form-field--full">
                    <input asp-for="IsActive" type="checkbox" />
                    <span>Промокодът е активен и може да се използва в checkout</span>
                </label>

                <div class="promo-form-actions promo-form-field--full">
                    <button type="submit" class="promo-form-btn promo-form-btn--primary">@(isEdit ? "Запази промените" : "Създай промокод")</button>
                    <a asp-action="Index" class="promo-form-btn promo-form-btn--ghost">Отказ</a>
                </div>
            </form>
        </div>
    </div>
</section>

<style>
    .promo-form-page { padding:2rem 0 4rem; }
    .promo-form-card { max-width:860px; margin:0 auto; padding:1.5rem; border-radius:18px; background:var(--sf-bg-card); border:1px solid rgba(255,255,255,.05); box-shadow:var(--sf-shadow); }
    .promo-form-card__header { display:flex; justify-content:space-between; gap:1rem; align-items:flex-start; margin-bottom:1.5rem; }
    .promo-form-card__eyebrow { display:inline-flex; gap:.5rem; align-items:center; padding:.5rem .85rem; border-radius:999px; color:var(--sf-green); background:rgba(0,255,156,.08); border:1px solid rgba(0,255,156,.18); }
    .promo-form-card h1 { margin:1rem 0 0; color:var(--sf-text); }
    .promo-form-card__back { color:var(--sf-text-muted); text-decoration:none; min-height:44px; display:inline-flex; align-items:center; padding:0 .9rem; border-radius:12px; border:1px solid rgba(255,255,255,.08); }
    .promo-form-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:1rem; }
    .promo-form-field { display:grid; gap:.45rem; }
    .promo-form-field--full { grid-column:1 / -1; }
    .promo-form-field span { color:var(--sf-text-muted); font-size:.9rem; }
    .promo-form-field input { min-height:48px; border-radius:12px; border:1px solid rgba(255,255,255,.1); background:rgba(255,255,255,.03); color:var(--sf-text); padding:0 .9rem; }
    .promo-form-switch { display:flex; align-items:center; gap:.75rem; padding:1rem; border-radius:14px; background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.06); }
    .promo-form-switch input { width:18px; height:18px; accent-color:#00ff9c; }
    .promo-form-actions { display:flex; gap:.75rem; flex-wrap:wrap; }
    .promo-form-btn { min-height:46px; padding:.8rem 1rem; border-radius:12px; display:inline-flex; align-items:center; justify-content:center; text-decoration:none; font-weight:700; }
    .promo-form-btn--primary { background:var(--sf-gradient); color:#000; border:none; }
    .promo-form-btn--ghost { background:transparent; color:var(--sf-text-muted); border:1px solid rgba(255,255,255,.08); }
    @@media (max-width: 767.98px) {
        .promo-form-page { padding-top:6.5rem; }
        .promo-form-card__header, .promo-form-grid { grid-template-columns:1fr; display:grid; }
        .promo-form-actions { display:grid; grid-template-columns:1fr; }
    }
</style>
