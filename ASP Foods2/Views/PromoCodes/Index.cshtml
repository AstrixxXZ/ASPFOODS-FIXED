@model IEnumerable<ASP_Foods2.Data.PromoCode>
@using System.Linq

@{
    ViewData["Title"] = "Промокодове";
    var promoCodes = (Model ?? Enumerable.Empty<ASP_Foods2.Data.PromoCode>()).ToList();
}

<section class="promo-admin-page">
    <div class="container">
        <div class="promo-admin-hero">
            <div>
                <span class="promo-admin-hero__eyebrow">
                    <i class="bi bi-ticket-perforated"></i>
                    Маркетинг инструменти
                </span>
                <h1>Промокодове</h1>
                <p>Създавай, редактирай и спирай кодове за отстъпка директно от админ панела.</p>
            </div>
            <div class="promo-admin-hero__actions">
                <a asp-controller="Admin" asp-action="Index" class="promo-admin-btn promo-admin-btn--ghost">Към админ панела</a>
                <a asp-action="Create" class="promo-admin-btn promo-admin-btn--primary">Нов промокод</a>
            </div>
        </div>

        @if (promoCodes.Any())
        {
            <div class="promo-admin-grid">
                @foreach (var promoCode in promoCodes)
                {
                    var isExpired = promoCode.ValidTo.HasValue && promoCode.ValidTo.Value < DateTime.Now;
                    var usageText = promoCode.UsageLimit.HasValue ? $"{promoCode.UsedCount}/{promoCode.UsageLimit}" : $"{promoCode.UsedCount}/Без лимит";

                    <article class="promo-admin-card">
                        <div class="promo-admin-card__header">
                            <div>
                                <span class="promo-admin-card__code">@promoCode.Code</span>
                                <h2>@promoCode.DiscountPercent.ToString("0.##")% отстъпка</h2>
                            </div>
                            <span class="promo-admin-card__state @(promoCode.IsActive && !isExpired ? "is-active" : "is-inactive")">
                                @(promoCode.IsActive && !isExpired ? "Активен" : "Неактивен")
                            </span>
                        </div>

                        <p class="promo-admin-card__description">
                            @(string.IsNullOrWhiteSpace(promoCode.Description) ? "Няма добавено описание." : promoCode.Description)
                        </p>

                        <div class="promo-admin-card__meta">
                            <div><span>Мин. сума</span><strong>@promoCode.MinimumOrderAmount.ToString("0.00") лв</strong></div>
                            <div><span>Използвания</span><strong>@usageText</strong></div>
                            <div><span>Начало</span><strong>@(promoCode.ValidFrom?.ToString("dd.MM.yyyy") ?? "Веднага")</strong></div>
                            <div><span>Край</span><strong>@(promoCode.ValidTo?.ToString("dd.MM.yyyy") ?? "Без край")</strong></div>
                        </div>

                        <div class="promo-admin-card__actions">
                            <a asp-action="Edit" asp-route-id="@promoCode.Id" class="promo-admin-btn promo-admin-btn--secondary">Редактирай</a>
                            <a asp-action="Delete" asp-route-id="@promoCode.Id" class="promo-admin-btn promo-admin-btn--danger">Изтрий</a>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="promo-admin-empty">
                <i class="bi bi-ticket-perforated"></i>
                <h2>Все още няма промокодове</h2>
                <p>Създай първия код и той веднага ще може да се използва по време на checkout.</p>
            </div>
        }
    </div>
</section>

<style>
    .promo-admin-page { padding: 2rem 0 4rem; }
    .promo-admin-hero { display:grid; grid-template-columns:minmax(0,1fr) auto; gap:1.25rem; align-items:end; margin-bottom:2rem; }
    .promo-admin-hero__eyebrow { display:inline-flex; gap:.55rem; align-items:center; padding:.5rem .85rem; border-radius:999px; background:rgba(0,255,156,.08); border:1px solid rgba(0,255,156,.2); color:var(--sf-green); font-size:.82rem; text-transform:uppercase; letter-spacing:.08em; }
    .promo-admin-hero h1 { margin:1rem 0 .6rem; color:var(--sf-text); }
    .promo-admin-hero p { margin:0; color:var(--sf-text-muted); max-width:60ch; }
    .promo-admin-hero__actions { display:flex; gap:.75rem; flex-wrap:wrap; }
    .promo-admin-btn { min-height:44px; padding:.8rem 1rem; border-radius:12px; display:inline-flex; align-items:center; justify-content:center; text-decoration:none; font-weight:700; }
    .promo-admin-btn--primary { background:var(--sf-gradient); color:#000; }
    .promo-admin-btn--secondary { background:rgba(255,255,255,.05); color:var(--sf-text); border:1px solid rgba(255,255,255,.08); }
    .promo-admin-btn--ghost { background:transparent; color:var(--sf-text-muted); border:1px solid rgba(255,255,255,.08); }
    .promo-admin-btn--danger { background:rgba(239,68,68,.1); color:#fecaca; border:1px solid rgba(239,68,68,.18); }
    .promo-admin-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:1rem; }
    .promo-admin-card { padding:1.25rem; border-radius:18px; background:var(--sf-bg-card); border:1px solid rgba(255,255,255,.05); box-shadow:var(--sf-shadow); }
    .promo-admin-card__header { display:flex; justify-content:space-between; gap:1rem; align-items:flex-start; margin-bottom:.9rem; }
    .promo-admin-card__code { display:inline-flex; padding:.25rem .6rem; border-radius:999px; background:rgba(0,255,156,.08); color:var(--sf-green); font-size:.82rem; font-weight:700; margin-bottom:.55rem; }
    .promo-admin-card h2 { margin:0; color:var(--sf-text); font-size:1.1rem; }
    .promo-admin-card__state { padding:.3rem .65rem; border-radius:999px; font-size:.8rem; font-weight:700; white-space:nowrap; }
    .promo-admin-card__state.is-active { background:rgba(34,197,94,.12); color:#86efac; }
    .promo-admin-card__state.is-inactive { background:rgba(148,163,184,.12); color:#cbd5e1; }
    .promo-admin-card__description { min-height:48px; color:var(--sf-text-muted); margin:0 0 1rem; }
    .promo-admin-card__meta { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:.8rem; margin-bottom:1rem; }
    .promo-admin-card__meta span { display:block; color:var(--sf-text-muted); font-size:.8rem; margin-bottom:.25rem; }
    .promo-admin-card__meta strong { color:var(--sf-text); word-break:break-word; }
    .promo-admin-card__actions { display:flex; gap:.75rem; flex-wrap:wrap; }
    .promo-admin-empty { padding:3rem 1.5rem; text-align:center; background:var(--sf-bg-card); border:1px dashed rgba(255,255,255,.08); border-radius:18px; }
    .promo-admin-empty i { font-size:2.5rem; color:var(--sf-green); }
    .promo-admin-empty h2 { margin:1rem 0 .5rem; color:var(--sf-text); }
    .promo-admin-empty p { margin:0; color:var(--sf-text-muted); }
    @@media (max-width: 767.98px) {
        .promo-admin-page { padding-top: 6.5rem; }
        .promo-admin-hero { grid-template-columns:1fr; }
        .promo-admin-hero__actions, .promo-admin-card__actions { display:grid; grid-template-columns:1fr; }
        .promo-admin-btn { width:100%; }
    }
</style>
