@model ASP_Foods2.Models.AdminProfileEditViewModel

@{
    ViewData["Title"] = "Редакция на профил";
}

<section class="admin-dashboard-page">
    <div class="container">
        <div class="admin-dashboard-hero">
            <div class="admin-dashboard-hero__content">
                <span class="admin-dashboard-eyebrow">
                    <i class="bi bi-pencil-square"></i>
                    Редакция
                </span>
                <h1>Редакция на профил</h1>
                <p>Промени основните данни на потребителя. Паролата не се редактира тук, а се занулява от детайлите на профила.</p>
            </div>
        </div>

        <section class="admin-panel-card admin-profile-form-card">
            <div class="admin-panel-card__header">
                <div>
                    <span class="admin-panel-card__eyebrow">Профил</span>
                    <h2>@Model.UserName</h2>
                </div>
                <a asp-action="ProfileDetails" asp-route-id="@Model.Id" class="admin-panel-card__link">
                    <i class="bi bi-arrow-left"></i>
                    Назад
                </a>
            </div>

            <form asp-action="EditProfile" asp-route-id="@Model.Id" method="post" class="admin-profile-form">
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="admin-profile-form-grid">
                    <div class="admin-profile-field">
                        <label asp-for="UserName"></label>
                        <input asp-for="UserName" />
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>

                    <div class="admin-profile-field">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="admin-profile-field">
                        <label asp-for="FirstName"></label>
                        <input asp-for="FirstName" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>

                    <div class="admin-profile-field">
                        <label asp-for="LastName"></label>
                        <input asp-for="LastName" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>

                    <div class="admin-profile-field">
                        <label asp-for="PhoneNumber"></label>
                        <input asp-for="PhoneNumber" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>

                    <label class="admin-profile-check">
                        <input asp-for="EmailConfirmed" />
                        <span><i class="bi bi-check-lg"></i></span>
                        Имейлът е потвърден
                    </label>
                </div>

                <div class="admin-profile-form-actions">
                    <button type="submit" class="btn-sf-primary admin-profile-save">
                        <i class="bi bi-save"></i>
                        Запази промените
                    </button>
                    <a asp-action="ProfileDetails" asp-route-id="@Model.Id" class="admin-panel-card__link">Отказ</a>
                </div>
            </form>
        </section>
    </div>
</section>

<style>
    .admin-profile-form-card {
        max-width: 900px;
        margin: 0 auto;
    }

    .admin-profile-form {
        display: grid;
        gap: 1.4rem;
    }

    .admin-profile-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .admin-profile-field {
        display: grid;
        gap: 0.45rem;
    }

    .admin-profile-field label {
        color: var(--sf-text-muted);
        font-weight: 700;
    }

    .admin-profile-field input {
        width: 100%;
        padding: 0.9rem 1rem;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.04);
        color: #fff;
        outline: none;
        transition: var(--sf-transition);
    }

    .admin-profile-field input:focus {
        border-color: var(--sf-green);
        box-shadow: 0 0 0 3px rgba(0, 255, 156, 0.1);
    }

    .admin-profile-check {
        min-height: 58px;
        margin: 1.95rem 0 0;
        padding: 0.9rem 1rem;
        border-radius: 12px;
        border: 1px solid rgba(0, 255, 156, 0.16);
        background: rgba(0, 255, 156, 0.06);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: #fff;
        font-weight: 700;
        cursor: pointer;
    }

    .admin-profile-check input {
        position: absolute;
        opacity: 0;
    }

    .admin-profile-check span {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 255, 255, 0.18);
        color: transparent;
        transition: var(--sf-transition);
    }

    .admin-profile-check input:checked + span {
        background: var(--sf-green);
        border-color: var(--sf-green);
        color: #000;
    }

    .admin-profile-form-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .admin-profile-save {
        width: auto;
        min-width: 220px;
    }

    @@media (max-width: 767px) {
        .admin-profile-form-grid {
            grid-template-columns: 1fr;
        }

        .admin-profile-check {
            margin-top: 0;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
