<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SuperFoods</title>
    <link rel="icon" type="image/png" href="~/images/MainLogo.png" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/MainLogo.png" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ASP_Foods2.styles.css" asp-append-version="true" />
</head>
@{
    var orderToastTitle = TempData["OrderToastTitle"] as string;
    var orderToastSummary = TempData["OrderToastSummary"] as string;
    var orderToastStatus = TempData["OrderToastStatus"] as string;
    var orderToastDate = TempData["OrderToastDate"] as string;
    var orderToastTotal = TempData["OrderToastTotal"] as string;
    var orderToastPromo = TempData["OrderToastPromo"] as string;
    var orderToastTargetUrl = TempData["OrderToastTargetUrl"] as string ?? "/Orders/My";
    var showOrderToast = !string.IsNullOrWhiteSpace(orderToastTitle);
    var successMessage = showOrderToast ? null : TempData["Success"] as string;
    var errorMessage = TempData["Error"] as string;
}
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-sf fixed-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index" aria-label="SuperFoods">
                    <img class="brand-icon" src="~/images/MainLogo.png" asp-append-version="true" alt="SuperFoods" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>Начало
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Products">
                                <i class="bi bi-box-seam me-1"></i>Продукти
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-admin" asp-area="" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-speedometer2 me-1"></i>Админ панел
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Polzi">
                                <i class="bi bi-heart-pulse me-1"></i>Ползи
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Contacts">
                                <i class="bi bi-envelope me-1"></i>Контакти
                            </a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a class="btn btn-cart" asp-controller="Carts" asp-action="Index" title="Количка">
                                <i class="bi bi-cart3"></i>
                                <span class="cart-label">Количка</span>
                            </a>
                        }
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @if (successMessage != null)
        {
            <div class="alert alert-success alert-dismissible fade show m-3" role="alert" style="position: fixed; top: 80px; right: 20px; z-index: 1050; max-width: 350px; background: rgba(0, 255, 156, 0.15); border: 1px solid var(--sf-green); color: var(--sf-green);">
                <i class="bi bi-check-circle me-2"></i>@successMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="filter: invert(1);"></button>
            </div>
        }
        @if (errorMessage != null)
        {
            <div class="alert alert-danger alert-dismissible fade show m-3" role="alert" style="position: fixed; top: 80px; right: 20px; z-index: 1050; max-width: 350px;">
                <i class="bi bi-exclamation-circle me-2"></i>@errorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (showOrderToast)
        {
            <div class="order-toast" data-order-toast>
                <button type="button" class="order-toast__bubble" data-order-toast-toggle aria-expanded="false">
                    <span class="order-toast__icon">
                        <i class="bi bi-chat-dots-fill"></i>
                    </span>
                    <span class="order-toast__copy">
                        <strong>@orderToastTitle</strong>
                        <small>Натисни за детайли</small>
                    </span>
                    <span class="order-toast__ping"></span>
                </button>

                <section class="order-toast__panel" data-order-toast-panel hidden aria-label="Информация за изпратена поръчка">
                    <div class="order-toast__panel-top">
                        <div>
                            <span class="order-toast__eyebrow">Поръчка</span>
                            <h4>@orderToastTitle</h4>
                        </div>
                        <button type="button" class="order-toast__close" data-order-toast-close aria-label="Затвори">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>

                    <div class="order-toast__grid">
                        @if (!string.IsNullOrWhiteSpace(orderToastSummary))
                        {
                            <div class="order-toast__item">
                                <span>Обобщение</span>
                                <strong>@orderToastSummary</strong>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(orderToastStatus))
                        {
                            <div class="order-toast__item">
                                <span>Статус</span>
                                <strong>@orderToastStatus</strong>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(orderToastDate))
                        {
                            <div class="order-toast__item">
                                <span>Изпратена на</span>
                                <strong>@orderToastDate</strong>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(orderToastTotal))
                        {
                            <div class="order-toast__item">
                                <span>Крайна сума</span>
                                <strong>@orderToastTotal лв.</strong>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(orderToastPromo))
                        {
                            <div class="order-toast__item order-toast__item--full">
                                <span>Промокод</span>
                                <strong>@orderToastPromo</strong>
                            </div>
                        }
                    </div>

                    <a href="@orderToastTargetUrl" class="order-toast__link">
                        <i class="bi bi-bag-check"></i>
                        <span>Отвори Моите поръчки</span>
                    </a>
                </section>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="footer-sf">
        <div class="container">
            <div class="row py-4">
                <div class="col-md-4 mb-3 mb-md-0">
                    <h5 class="footer-brand"><img class="brand-icon" src="~/images/MainLogo.png" asp-append-version="true" alt="SuperFoods logo" /> SuperFoods</h5>
                    <p class="text-muted-light small">Натурални суперхрани за здравословен начин на живот.</p>
                </div>
                <div class="col-md-4 mb-3 mb-md-0">
                    <h6 class="text-uppercase mb-3">Навигация</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a asp-controller="Home" asp-action="Index">Начало</a></li>
                        <li><a asp-controller="Home" asp-action="Products">Продукти</a></li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li><a asp-controller="Admin" asp-action="Index">Админ панел</a></li>
                        }
                        <li><a asp-controller="Home" asp-action="Polzi">Ползи</a></li>
                        <li><a asp-controller="Home" asp-action="Contacts">Контакти</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-uppercase mb-3">Социални мрежи</h6>
                    <div class="social-icons">
                        <a href="#" class="social-icon"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-twitter-x"></i></a>
                    </div>
                </div>
            </div>
            <hr class="footer-divider">
            <div class="text-center py-2">
                <small>&copy; 2026 SuperFoods. Всички права запазени.</small>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (showOrderToast)
    {
        <script>
            (() => {
                const toast = document.querySelector('[data-order-toast]');
                if (!toast) return;

                const toggle = toast.querySelector('[data-order-toast-toggle]');
                const close = toast.querySelector('[data-order-toast-close]');
                const panel = toast.querySelector('[data-order-toast-panel]');

                const setExpanded = (expanded) => {
                    toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
                    panel.hidden = !expanded;
                    toast.classList.toggle('order-toast--open', expanded);
                };

                toggle.addEventListener('click', () => {
                    const expanded = toggle.getAttribute('aria-expanded') === 'true';
                    setExpanded(!expanded);
                });

                close.addEventListener('click', (event) => {
                    event.stopPropagation();
                    setExpanded(false);
                });

                document.addEventListener('click', (event) => {
                    if (!toast.contains(event.target)) {
                        setExpanded(false);
                    }
                });
            })();
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
