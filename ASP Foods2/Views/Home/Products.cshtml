@model IEnumerable<ASP_Foods2.Data.Product>
@{
    ViewData["Title"] = "Продукти";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var productsReturnUrl = Url.Action("Products", "Home");
}

<div class="page-hero product-catalog-hero">
    <div class="container">
        <h1>Натурални <span class="text-gradient">Суперхрани</span></h1>
        <p>Подбрани продукти за ежедневна енергия, силен имунитет и устойчив тонус.</p>
    </div>
</div>

<div class="container product-catalog-page">
    <section class="sf-section" style="padding-top: 0;">
        @if (Model != null && Model.Any())
        {
            <div class="sf-grid">
                @foreach (var product in Model)
                {
                    <article class="sf-card sf-product-card">
                        <div class="product-image" style="background: radial-gradient(circle, rgba(0,255,156,0.1) 0%, transparent 70%); display: flex; align-items: center; justify-content: center; overflow: hidden;">
                            @if (!string.IsNullOrWhiteSpace(product.ImageLink))
                            {
                                <img src="@product.ImageLink" alt="@product.Name" style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <span style="font-size: 4rem;">🌿</span>
                            }
                        </div>
                        <div class="product-info">
                            <h3>@product.Name</h3>
                            <p class="product-description">@product.Description</p>
                            <div class="product-meta">
                                @if (product.Categories != null)
                                {
                                    <span class="sf-tag-small">@product.Categories.Name</span>
                                }
                                @if (product.Brands != null)
                                {
                                    <span class="sf-tag-small">@product.Brands.Name</span>
                                }
                            </div>
                            <div class="product-footer">
                                <div class="product-price">@product.Price.ToString("F2") лв</div>
                                <div class="product-actions">
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="btn-details">
                                        <i class="bi bi-eye me-1"></i>Детайли
                                    </a>
                                    @if (isAuthenticated)
                                    {
                                        <form asp-controller="Carts" asp-action="AddToCart" method="post" style="display: inline;">
                                            <input type="hidden" name="productId" value="@product.Id" />
                                            <input type="hidden" name="quantity" value="1" />
                                            <button type="submit" class="btn-buy">
                                                <i class="bi bi-cart-plus me-1"></i>Купи
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@productsReturnUrl" class="btn-buy">
                                            <i class="bi bi-cart-plus me-1"></i>Купи
                                        </a>
                                    }
                                </div>
                            </div>
                            @if (!isAuthenticated)
                            {
                                <p class="guest-buy-note">При натискане ще трябва да влезеш в акаунт или да си направиш регистрация.</p>
                            }
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="bi bi-box-seam"></i>
                </div>
                <h3>Няма налични продукти</h3>
                <p>В момента няма добавени продукти в магазина.</p>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Products" asp-action="Create" class="btn-sf-hero" style="margin-top: 1rem;">
                        <i class="bi bi-plus-lg me-2"></i>Добави продукт
                    </a>
                }
            </div>
        }
    </section>

    @if (User.IsInRole("Admin"))
    {
        <section class="sf-section">
            <div class="admin-actions">
                <h4 style="margin-bottom: 1rem; color: var(--sf-text-muted);">
                    <i class="bi bi-gear me-2"></i>Администраторски действия
                </h4>
                <div class="d-flex gap-3 flex-wrap">
                    <a asp-controller="Products" asp-action="Index" class="btn-admin">
                        <i class="bi bi-list-ul me-2"></i>Управление на продукти
                    </a>
                    <a asp-controller="Products" asp-action="Create" class="btn-admin">
                        <i class="bi bi-plus-lg me-2"></i>Добави нов продукт
                    </a>
                    <a asp-controller="Categories" asp-action="Index" class="btn-admin">
                        <i class="bi bi-tags me-2"></i>Категории
                    </a>
                    <a asp-controller="Brands" asp-action="Index" class="btn-admin">
                        <i class="bi bi-award me-2"></i>Марки
                    </a>
                </div>
            </div>
        </section>
    }
</div>

<style>
    .product-catalog-hero {
        padding: 6.5rem 0 1.6rem;
    }

    .product-catalog-hero h1 {
        font-size: clamp(1.7rem, 3vw, 2.65rem);
        margin-bottom: 0.45rem;
        letter-spacing: 0;
    }

    .product-catalog-hero p {
        font-size: 0.95rem;
        max-width: 520px;
        line-height: 1.45;
    }

    .product-catalog-page .sf-section {
        padding-bottom: 2.5rem;
    }

    .product-catalog-page .sf-grid {
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 0.85rem;
    }

    .product-catalog-page .sf-card {
        padding: 0.9rem;
        gap: 0.72rem;
        border-radius: 8px;
        box-shadow: 0 14px 32px rgba(0, 0, 0, 0.34);
    }

    .product-catalog-page .sf-card:hover {
        transform: translateY(-3px);
    }

    .product-catalog-page .sf-product-card .product-image {
        height: 145px;
        padding: 0.65rem;
        margin-bottom: 0.15rem;
        border-radius: 8px;
    }

    .product-catalog-page .sf-card h3 {
        font-size: 1.02rem;
        line-height: 1.2;
    }

    .product-info {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
        flex-grow: 1;
    }

    .product-description {
        font-size: 0.82rem;
        color: var(--sf-text-muted);
        line-height: 1.38;
        flex-grow: 1;
        margin-bottom: 0;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 4;
        overflow: hidden;
    }

    .product-meta {
        display: flex;
        gap: 0.35rem;
        flex-wrap: wrap;
    }

    .sf-tag-small {
        padding: 0.22rem 0.55rem;
        font-size: 0.68rem;
        border-radius: 999px;
        background: rgba(0, 255, 156, 0.08);
        border: 1px solid rgba(0, 255, 156, 0.2);
        color: var(--sf-green);
        font-weight: 500;
    }

    .product-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.55rem;
        margin-top: auto;
        padding-top: 0.65rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .product-actions {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .product-catalog-page .sf-product-card .product-price {
        font-size: 1.08rem;
        white-space: nowrap;
    }

    .btn-details {
        display: inline-flex;
        align-items: center;
        padding: 0.48rem 0.72rem;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--sf-text);
        font-size: 0.82rem;
        font-weight: 600;
        text-decoration: none;
        transition: var(--sf-transition);
    }

    .btn-details:hover {
        background: rgba(0, 255, 156, 0.1);
        border-color: var(--sf-green-border);
        color: var(--sf-green);
    }

    .guest-buy-note {
        margin: 0.35rem 0 0;
        color: var(--sf-text-muted);
        font-size: 0.74rem;
        line-height: 1.35;
    }

    .product-catalog-page .sf-product-card .btn-buy {
        width: auto;
        margin-top: 0;
        padding: 0.48rem 0.78rem;
        border-radius: 8px;
        font-size: 0.82rem;
    }

    .empty-state {
        text-align: center;
        padding: 2rem 1.2rem;
        background: var(--sf-bg-card);
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.04);
    }

    .empty-state-icon {
        font-size: 2.4rem;
        color: var(--sf-text-muted);
        margin-bottom: 0.8rem;
    }

    .empty-state h3 {
        color: var(--sf-text);
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: var(--sf-text-muted);
    }

    .admin-actions {
        background: rgba(255, 193, 7, 0.05);
        border: 1px solid rgba(255, 193, 7, 0.2);
        border-radius: 8px;
        padding: 1rem;
    }

    .btn-admin {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 0.8rem;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--sf-text);
        font-size: 0.82rem;
        font-weight: 500;
        text-decoration: none;
        transition: var(--sf-transition);
    }

    .btn-admin:hover {
        background: rgba(0, 255, 156, 0.1);
        border-color: var(--sf-green-border);
        color: var(--sf-green);
    }

    @@media (max-width: 767px) {
        .product-catalog-hero {
            padding: 5.8rem 0 1.1rem;
        }

        .product-catalog-page .sf-grid {
            grid-template-columns: 1fr;
        }

        .product-footer {
            flex-direction: column;
            align-items: flex-start;
        }

        .product-actions {
            width: 100%;
            justify-content: flex-start;
        }

        .product-catalog-page .sf-product-card .btn-buy,
        .btn-details {
            flex: 1 1 0;
            justify-content: center;
        }
    }
</style>

