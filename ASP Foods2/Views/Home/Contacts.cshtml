@{
    ViewData["Title"] = "Контакти";
    var contactName = ViewData["ContactName"] as string ?? string.Empty;
    var contactEmail = ViewData["ContactEmail"] as string ?? string.Empty;
    var contactSubject = ViewData["ContactSubject"] as string ?? string.Empty;
    var contactMessage = ViewData["ContactMessage"] as string ?? string.Empty;
    var contactSuccess = TempData["ContactSuccess"] as string;
    var contactError = TempData["ContactError"] as string;
}

<div class="page-hero compact-page-hero contacts-page-hero">
    <div class="container">
        <h1>Свържете се с <span class="text-gradient">Нас</span></h1>
        <p>Имате въпроси? Ще се радваме да ви помогнем. Свържете се с нашия екип.</p>
    </div>
</div>

<div class="container contacts-page">
    <section class="sf-section" style="padding-top: 0;">
        <div class="contact-grid">
            <div class="contact-info">
                <div class="contact-item">
                    <div class="contact-item-icon">
                        <i class="bi bi-geo-alt"></i>
                    </div>
                    <div>
                        <h5>Адрес</h5>
                        <p>ул. Здравословна 123<br>София 1000, България</p>
                    </div>
                </div>

                <div class="contact-item">
                    <div class="contact-item-icon">
                        <i class="bi bi-telephone"></i>
                    </div>
                    <div>
                        <h5>Телефон</h5>
                        <p>+359 888 123 456<br>Пон-Пет: 9:00 - 18:00</p>
                    </div>
                </div>

                <div class="contact-item">
                    <div class="contact-item-icon">
                        <i class="bi bi-envelope"></i>
                    </div>
                    <div>
                        <h5>Имейл</h5>
                        <p>info@superfoods.bg<br>support@superfoods.bg</p>
                    </div>
                </div>

                <div class="contact-item">
                    <div class="contact-item-icon">
                        <i class="bi bi-clock"></i>
                    </div>
                    <div>
                        <h5>Работно Време</h5>
                        <p>Понеделник - Петък: 9:00 - 18:00<br>Събота: 10:00 - 14:00</p>
                    </div>
                </div>
            </div>

            <div class="contact-form">
                <h3 style="margin-bottom: 1.5rem; font-weight: 700;">Изпратете съобщение</h3>

                @if (!string.IsNullOrWhiteSpace(contactSuccess))
                {
                    <div class="alert alert-success" role="alert">@contactSuccess</div>
                }
                @if (!string.IsNullOrWhiteSpace(contactError))
                {
                    <div class="alert alert-danger" role="alert">@contactError</div>
                }

                <form asp-action="Contacts" asp-controller="Home" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label" for="contact-name">Вашето име</label>
                        <input id="contact-name" type="text" name="name" class="form-control" placeholder="Иван Иванов" value="@contactName" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="contact-email">Имейл адрес</label>
                        <input id="contact-email" type="email" name="email" class="form-control" placeholder="ivan@example.com" value="@contactEmail" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="contact-subject">Тема</label>
                        <input id="contact-subject" type="text" name="subject" class="form-control" placeholder="Въпрос относно продукт" value="@contactSubject" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label" for="contact-message">Съобщение</label>
                        <textarea id="contact-message" name="message" class="form-control" rows="5" placeholder="Напишете вашето съобщение тук..." required>@contactMessage</textarea>
                    </div>
                    <button type="submit" class="btn-sf-submit">
                        <i class="bi bi-send"></i> Изпрати съобщение
                    </button>
                </form>
            </div>
        </div>
    </section>

    <section class="sf-section">
        <div class="sf-section-title">
            <h2>Често задавани <span class="text-gradient">въпроси</span></h2>
        </div>
        <div class="sf-grid contacts-faq-grid">
            <div class="sf-card">
                <h3>Как мога да направя поръчка?</h3>
                <p>Изберете продуктите, добавете ги в количката и следвайте стъпките за плащане. Приемаме карти и наложен платеж.</p>
            </div>
            <div class="sf-card">
                <h3>Какви са сроковете за доставка?</h3>
                <p>Доставяме до 48 часа в работни дни до всяка точка в България. Безплатна доставка при поръчки над 100 лв.</p>
            </div>
            <div class="sf-card">
                <h3>Мога ли да върна продукт?</h3>
                <p>Да, имате право на връщане до 14 дни от получаването, ако продуктът е в оригинална опаковка.</p>
            </div>
        </div>
    </section>
</div>

<style>
    .contacts-page .sf-section {
        padding-bottom: 2rem;
    }

    .contacts-page .contact-grid {
        grid-template-columns: minmax(260px, 0.75fr) minmax(0, 1fr);
        gap: 0.9rem;
        align-items: start;
    }

    .contacts-page .contact-info {
        gap: 0.65rem;
    }

    .contacts-page .contact-item,
    .contacts-page .contact-form,
    .contacts-page .sf-card {
        border-radius: 8px;
        box-shadow: 0 14px 32px rgba(0, 0, 0, 0.32);
    }

    .contacts-page .contact-item {
        padding: 0.85rem;
        gap: 0.7rem;
    }

    .contacts-page .contact-item:hover {
        transform: translateY(-2px);
    }

    .contacts-page .contact-item-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        font-size: 0.95rem;
    }

    .contacts-page .contact-item h5 {
        font-size: 0.95rem;
    }

    .contacts-page .contact-item p {
        font-size: 0.82rem;
        line-height: 1.35;
    }

    .contacts-page .contact-form {
        padding: 1rem;
    }

    .contacts-page .contact-form h3 {
        margin-bottom: 0.8rem !important;
        font-size: 1.15rem;
    }

    .contacts-page .contact-form .mb-3 {
        margin-bottom: 0.65rem !important;
    }

    .contacts-page .contact-form .mb-4 {
        margin-bottom: 0.85rem !important;
    }

    .contacts-page .contact-form .form-label {
        font-size: 0.82rem;
        margin-bottom: 0.28rem;
    }

    .contacts-page .contact-form .form-control {
        padding: 0.62rem 0.75rem;
        border-radius: 8px;
        font-size: 0.9rem;
    }

    .contacts-page .contact-form textarea {
        min-height: 108px;
    }

    .contacts-page .btn-sf-submit {
        padding: 0.68rem 1rem;
        border-radius: 8px;
        font-size: 0.9rem;
    }

    .contacts-faq-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.85rem;
    }

    .contacts-faq-grid .sf-card {
        padding: 1rem;
    }

    .contacts-faq-grid .sf-card h3 {
        font-size: 1rem;
        line-height: 1.2;
    }

    .contacts-faq-grid .sf-card p {
        font-size: 0.84rem;
        line-height: 1.42;
    }

    @@media (max-width: 991px) {
        .contacts-page .contact-grid,
        .contacts-faq-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
