@model IEnumerable<ASP_Foods2.Data.Cart>
@{
    ViewData["Title"] = "Количка";
    var total = Model?.Sum(c => c.Products?.Price * c.Quantity ?? 0) ?? 0;
}

<div class="page-hero compact-page-hero cart-page-hero">
    <div class="container">
        <h1><i class="bi bi-cart3 me-2"></i><span class="text-gradient">Количка</span></h1>
        <p>Прегледай избраните продукти преди финализиране на поръчката.</p>
    </div>
</div>

<div class="container cart-page">
    <section class="sf-section" style="padding-top: 0;">
        @if (Model != null && Model.Any())
        {
            <div class="cart-layout">
                <div class="cart-items-list">
                    @foreach (var item in Model)
                    {
                        var itemTotal = (item.Products?.Price ?? 0) * item.Quantity;
                        <article class="cart-line-item">
                            <div class="cart-product-icon"><i class="bi bi-box-seam"></i></div>
                            <div class="cart-line-main">
                                <h2>@item.Products?.Name</h2>
                                <span>@((item.Products?.Price ?? 0).ToString("F2")) лв / бр.</span>
                            </div>
                            <form asp-controller="Carts" asp-action="UpdateQuantity" method="post" class="cart-quantity-form">
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="number" name="quantity" value="@item.Quantity" min="1" class="cart-quantity-input" aria-label="Количество" />
                                <button type="submit" class="cart-update-btn" aria-label="Обнови количество">
                                    <i class="bi bi-check-lg"></i>
                                </button>
                            </form>
                            <div class="cart-line-price">@itemTotal.ToString("F2") лв</div>
                            <form asp-controller="Carts" asp-action="RemoveFromCart" method="post">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="cart-remove-btn" aria-label="Премахни продукта">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </form>
                        </article>
                    }
                </div>

                <aside class="cart-summary">
                    <h4><i class="bi bi-receipt me-2"></i>Обобщение</h4>
                    <div class="cart-summary-row">
                        <span>Продукти (@Model.Sum(c => c.Quantity))</span>
                        <span>@total.ToString("F2") лв</span>
                    </div>
                    <div class="cart-summary-row">
                        <span>Доставка</span>
                        <span class="cart-free-delivery">Безплатна</span>
                    </div>
                    <div class="cart-summary-row cart-summary-row--total">
                        <span>Общо</span>
                        <span class="cart-summary-total">@total.ToString("F2") лв</span>
                    </div>
                    <a asp-controller="Orders" asp-action="Create" class="btn-sf-primary cart-checkout-btn">
                        <i class="bi bi-credit-card me-2"></i>Към поръчка
                    </a>
                    <a asp-controller="Home" asp-action="Products" class="cart-back-link">
                        <i class="bi bi-arrow-left me-1"></i>Продължи пазаруването
                    </a>
                </aside>
            </div>
        }
        else
        {
            <div class="empty-state cart-empty-state">
                <div class="empty-state-icon">
                    <i class="bi bi-cart-x"></i>
                </div>
                <h3>Количката е празна</h3>
                <p>Все още нямаш добавени продукти.</p>
                <a asp-controller="Home" asp-action="Products" class="btn-sf-hero">
                    <i class="bi bi-box-seam me-2"></i>Разгледай продуктите
                </a>
            </div>
        }
    </section>
</div>

<style>
    .cart-page .sf-section { padding-bottom: 2.5rem; }
    .cart-layout { display: grid; grid-template-columns: minmax(0, 1fr) minmax(260px, 0.38fr); gap: 0.9rem; align-items: start; }
    .cart-items-list { display: grid; gap: 0.65rem; }
    .cart-line-item, .cart-summary, .cart-empty-state { background: var(--sf-bg-card); border: 1px solid rgba(255,255,255,.05); border-radius: 8px; box-shadow: 0 14px 32px rgba(0,0,0,.32); }
    .cart-line-item { display: grid; grid-template-columns: 42px minmax(0, 1fr) auto auto 38px; gap: 0.7rem; align-items: center; padding: 0.75rem; }
    .cart-line-main h2 { margin: 0; font-size: 1rem; line-height: 1.2; color: #fff; }
    .cart-line-main span { color: var(--sf-text-muted); font-size: 0.82rem; }
    .cart-product-icon { width: 42px; height: 42px; border-radius: 8px; background: rgba(0,255,156,.1); color: var(--sf-green); display: flex; align-items: center; justify-content: center; font-size: 1rem; }
    .cart-quantity-form { display: flex; align-items: center; gap: 0.35rem; }
    .cart-quantity-input { width: 58px; padding: 0.45rem; border-radius: 8px; border: 1px solid rgba(255,255,255,.1); background: rgba(255,255,255,.05); color: #fff; text-align: center; }
    .cart-update-btn, .cart-remove-btn { width: 34px; height: 34px; border-radius: 8px; border: 1px solid transparent; display: inline-flex; align-items: center; justify-content: center; }
    .cart-update-btn { background: rgba(0,255,156,.1); color: var(--sf-green); }
    .cart-remove-btn { padding: 0; background: rgba(255,107,107,.1); border-color: rgba(255,107,107,.24); color: #ff6b6b; }
    .cart-line-price { min-width: 88px; text-align: right; color: var(--sf-green); font-weight: 800; font-size: 1rem; }
    .cart-summary { position: sticky; top: 6rem; padding: 1rem; }
    .cart-summary h4 { margin-bottom: 0.85rem; font-size: 1.05rem; }
    .cart-summary-row { display: flex; justify-content: space-between; gap: 1rem; padding: 0.62rem 0; color: var(--sf-text-muted); border-bottom: 1px solid rgba(255,255,255,.06); font-size: 0.9rem; }
    .cart-summary-row--total { color: #fff; font-weight: 800; border-bottom: 0; }
    .cart-free-delivery, .cart-summary-total { color: var(--sf-green); }
    .cart-summary-total { font-size: 1.2rem; }
    .cart-checkout-btn { margin-top: 0.85rem; padding: 0.7rem 1rem; border-radius: 8px; text-decoration: none; }
    .cart-back-link { display: block; margin-top: 0.8rem; color: var(--sf-text-muted); text-align: center; font-size: 0.86rem; text-decoration: none; }
    .cart-empty-state { text-align: center; padding: 2rem 1rem; }
    .cart-empty-state .empty-state-icon { font-size: 2.4rem; color: var(--sf-text-muted); margin-bottom: 0.8rem; }
    .cart-empty-state .btn-sf-hero { margin-top: 1rem; padding: 0.7rem 1rem; border-radius: 8px; font-size: 0.9rem; }
    @@media (max-width: 991px) { .cart-layout { grid-template-columns: 1fr; } .cart-summary { position: static; } }
    @@media (max-width: 767px) { .cart-line-item { grid-template-columns: 38px minmax(0, 1fr) 34px; } .cart-quantity-form, .cart-line-price { grid-column: 2 / 4; justify-content: flex-start; text-align: left; } }
</style>
