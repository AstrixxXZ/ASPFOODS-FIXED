        font-weight: 500;
    }

    .product-details-actions {
        display: flex;
        gap: 1rem;
        margin-top: 1.5rem;
        flex-wrap: wrap;
    }

    @@media (max-width: 768px) {
        .product-details-card {
            grid-template-columns: 1fr;
        }
    }

</style>
