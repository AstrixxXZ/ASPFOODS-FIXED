@model ASP_Foods2.Data.Product

@{
    ViewData["Title"] = "–î–Β―²–Α–Ι–Μ–Η –Ζ–Α –Ω―Ä–Ψ–¥―É–Κ―²";
    var productIdString = Model?.Id.ToString();
}

<div class="page-hero" style="padding-bottom: 2rem;">
    <div class="container">
        <h1><i class="bi bi-eye me-3"></i>–î–Β―²–Α–Ι–Μ–Η –Ζ–Α <span class="text-gradient">–ü―Ä–Ψ–¥―É–Κ―²</span></h1>
        <p>–ü―ä–Μ–Β–Ϋ –Ω―Ä–Β–≥–Μ–Β–¥ –Ϋ–Α –Η–Ϋ―³–Ψ―Ä–Φ–Α―Ü–Η―è―²–Α –Η ―¹–Ϋ–Η–Φ–Κ–Α―²–Α –Ϋ–Α –Ω―Ä–Ψ–¥―É–Κ―²–Α</p>
    </div>
</div>

<div class="container">

    <div class="product-details-card">

        <!-- IMAGE SECTION -->
        <div class="product-details-media">

            @if (Model != null && !string.IsNullOrWhiteSpace(Model.ImageLink))
            {
                <img src="@Model.ImageLink"
                     alt="@Model.Name"
                     class="product-details-image"
                     onerror="this.style.display='none'; this.parentElement.querySelector('.product-details-placeholder').style.display='flex';" />
                <div class="product-details-placeholder" style="display: none;">
                    <i class="bi bi-card-image"></i>
                    <span>–†―€–Γ–è–†―‰–†¬Α –†―î–†¬Α–ΓβÄΓ–†¬Β–†–Ö–†¬Α –Γ–É–†–Ö–†―ë–†―‰–†―î–†¬Α</span>
                </div>
            }
            else
            {
                <div class="product-details-placeholder">
                    <i class="bi bi-card-image"></i>
                    <span>–ù―è–Φ–Α –Κ–Α―΅–Β–Ϋ–Α ―¹–Ϋ–Η–Φ–Κ–Α</span>
                </div>
            }

        </div>

        <!-- CONTENT SECTION -->
        <div class="product-details-content">

            <h2>@Model.Name</h2>

            <p class="product-details-description">
                @Model.Description
            </p>

            <dl class="row product-details-list">

                <dt class="col-sm-4">–ö–Α―²–Α–Μ–Ψ–Ε–Β–Ϋ –Ϋ–Ψ–Φ–Β―Ä</dt>
                <dd class="col-sm-8">@Model.CatalogId</dd>

                <dt class="col-sm-4">–ö–Α―²–Β–≥–Ψ―Ä–Η―è</dt>
                <dd class="col-sm-8">@Model.Categories?.Name</dd>

                <dt class="col-sm-4">–Δ–Η–Ω</dt>
                <dd class="col-sm-8">@Model.TypeProducts?.Name</dd>

                <dt class="col-sm-4">–€–Α―Ä–Κ–Α</dt>
                <dd class="col-sm-8">@Model.Brands?.Name</dd>

                <dt class="col-sm-4">–ö–Ψ–Μ–Η―΅–Β―¹―²–≤–Ψ</dt>
                <dd class="col-sm-8">@Model.Quantity @Model.Units?.Name</dd>

                <dt class="col-sm-4">–Π–Β–Ϋ–Α</dt>
                <dd class="col-sm-8 text-success">@Model.Price.ToString("F2") –Μ–≤</dd>

                <dt class="col-sm-4">–î–Ψ–±–Α–≤–Β–Ϋ</dt>
                <dd class="col-sm-8">@Model.DateAdded.ToString("dd.MM.yyyy")</dd>

            </dl>

            <div class="product-details-actions">

                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit"
                   asp-route-id="@Model?.Id"
                   class="btn-admin-primary">
                    –†–Β–¥–Α–Κ―²–Η―Ä–Α–Ι
                    </a>
                }

                <a asp-action="Index"
                   class="btn-admin-secondary">
                    –ù–Α–Ζ–Α–¥ –Κ―ä–Φ ―¹–Ω–Η―¹―ä–Κ–Α
                </a>

            </div>

        </div>

    </div>

</div>

<style>

    .product-details-card {
        display: grid;
        grid-template-columns: minmax(260px, 340px) 1fr;
        gap: 2rem;
        background: var(--sf-bg-card);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: var(--sf-radius-lg);
        padding: 2rem;
        margin-bottom: 3rem;
    }

    .product-details-media {
        border-radius: 20px;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.03);
        min-height: 320px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-details-image {
        width: 100%;
        height: 320px;
        object-fit: cover;
    }

    .product-details-placeholder {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        align-items: center;
        justify-content: center;
        color: var(--sf-text-muted);
    }

        .product-details-placeholder i {
            font-size: 2.2rem;
            color: var(--sf-green);
        }

    .product-details-content h2 {
        margin-bottom: 0.75rem;
        color: var(--sf-text);
        font-weight: 800;
    }

    .product-details-description {
        color: var(--sf-text-muted);
        line-height: 1.7;
        margin-bottom: 1.5rem;
    }

    .product-details-list dt,
    .product-details-list dd {
        padding: 0.6rem 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .product-details-list dt {
