@model ASP_Foods2.Data.Category

@{
    ViewData["Title"] = "Редактирай категория";
}

<div class="page-hero" style="padding-bottom: 2rem;">
    <div class="container">
        <h1><i class="bi bi-pencil-square me-3"></i>Редактирай <span class="text-gradient">Категория</span></h1>
        <p>Промени информацията за категорията</p>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="admin-form-card">
                <div class="admin-form-header" style="background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(59, 130, 246, 0.02) 100%);">
                    <div class="admin-form-icon" style="background: linear-gradient(135deg, #3b82f6, #60a5fa);">
                        <i class="bi bi-pencil"></i>
                    </div>
                    <div>
                        <h3>@Model.Name</h3>
                        <p>Редактиране на категория</p>
                    </div>
                </div>

                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="form-section">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Име на категорията</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-tag"></i></span>
                                <input asp-for="Name" class="form-control" placeholder="Въведете име на категорията" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-actions">
                        <a asp-action="Index" class="btn-admin-secondary">
                            <i class="bi bi-x-lg me-2"></i>Отказ
                        </a>
                        <div class="d-flex gap-2">
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-admin-danger">
                                <i class="bi bi-trash3 me-2"></i>Изтрий
                            </a>
                            <button type="submit" class="btn-admin-primary">
                                <i class="bi bi-check-lg me-2"></i>Запази
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-form-card {
        background: var(--sf-bg-card);
        border-radius: var(--sf-radius-lg);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 0;
        overflow: hidden;
        margin-bottom: 3rem;
    }

    .admin-form-header {
        padding: 2rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .admin-form-icon {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #fff;
    }

    .admin-form-header h3 {
        margin: 0;
        font-weight: 700;
        color: var(--sf-text);
    }

    .admin-form-header p {
        margin: 0.25rem 0 0;
        color: var(--sf-text-muted);
        font-size: 0.9rem;
    }

    .form-section {
        padding: 2rem;
    }

    .form-label {
        color: var(--sf-text-muted);
        font-weight: 500;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .form-control {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        transition: var(--sf-transition);
    }

    .form-control:focus {
        background: rgba(255, 255, 255, 0.05);
        border-color: var(--sf-green);
        box-shadow: 0 0 0 3px rgba(0, 255, 156, 0.1);
        color: #fff;
    }

    .input-group-text {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--sf-green);
        border-radius: 10px 0 0 10px;
    }

    .input-group .form-control {
        border-radius: 0 10px 10px 0;
    }

    .form-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 2rem;
        background: rgba(0, 0, 0, 0.2);
        gap: 1rem;
    }

    .btn-admin-primary {
        display: inline-flex;
        align-items: center;
        padding: 0.9rem 2rem;
        border-radius: 12px;
        background: var(--sf-gradient);
        color: #000;
        font-weight: 700;
        font-size: 1rem;
        border: none;
        cursor: pointer;
        transition: var(--sf-transition);
        text-decoration: none;
    }

    .btn-admin-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(0, 255, 156, 0.3);
        color: #000;
    }

    .btn-admin-secondary {
        display: inline-flex;
        align-items: center;
        padding: 0.9rem 1.5rem;
        border-radius: 12px;
        background: transparent;
        color: var(--sf-text-muted);
        font-weight: 600;
        font-size: 0.95rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        cursor: pointer;
        transition: var(--sf-transition);
        text-decoration: none;
    }

    .btn-admin-secondary:hover {
        border-color: var(--sf-green);
        color: var(--sf-green);
    }

    .btn-admin-danger {
        display: inline-flex;
        align-items: center;
        padding: 0.9rem 1.5rem;
        border-radius: 12px;
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        font-weight: 600;
        font-size: 0.95rem;
        border: 1px solid rgba(239, 68, 68, 0.3);
        cursor: pointer;
        transition: var(--sf-transition);
        text-decoration: none;
    }

    .btn-admin-danger:hover {
        background: rgba(239, 68, 68, 0.2);
        color: #ef4444;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
